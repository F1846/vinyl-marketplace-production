# --------------------------------------------------------------------
# Core app
# Replace every example value before using this repo for a real store.
# --------------------------------------------------------------------

DATABASE_URL=postgresql://username:password@host:5432/database?sslmode=require
NEXT_PUBLIC_SITE_URL=http://localhost:3000
GOOGLE_SITE_VERIFICATION=
TRUST_PROXY_HEADERS=false

# --------------------------------------------------------------------
# Admin and internal secrets
# --------------------------------------------------------------------

ADMIN_PASSWORD=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=
CHECKOUT_STATE_SECRET=
INVOICE_DOWNLOAD_SECRET=
CRON_SECRET=

# --------------------------------------------------------------------
# Payments
# PAYPAL_ENVIRONMENT should be sandbox or live.
# --------------------------------------------------------------------

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_ENVIRONMENT=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
NEXT_PUBLIC_PAYPAL_ENABLED=true

# --------------------------------------------------------------------
# Email
# Use a verified sending domain before production traffic.
# --------------------------------------------------------------------

MAILGUN_API_KEY=
MAILGUN_DOMAIN=mg.your-domain.example
MAILGUN_BASE_URL=https://api.mailgun.net
EMAIL_FROM=Your Store <orders@your-domain.example>
EMAIL_FROM_NAME=Your Store
EMAIL_BCC=

# --------------------------------------------------------------------
# Tracking
# TRACKING_PROVIDER can be ship24, 17track, or aftership.
# --------------------------------------------------------------------

TRACKING_PROVIDER=ship24
SHIP24_API_KEY=
SEVENTEENTRACK_API_KEY=
AFTERSHIP_API_KEY=

# --------------------------------------------------------------------
# Store identity and legal profile
# These values are read by the site profile, legal pages, and checkout.
# --------------------------------------------------------------------

STORE_OWNER=Your Store
STORE_ORDER_EMAIL=orders@your-domain.example
STORE_SUPPORT_EMAIL=support@your-domain.example
STORE_CONTACT_EMAIL=orders@your-domain.example
STORE_SUPPORT_CONTACT_EMAIL=support@your-domain.example
STORE_ADDRESS_LINE1=123 Example Street
STORE_ADDRESS_LINE2=
STORE_POSTAL_CODE=12345
STORE_CITY=Example City
STORE_COUNTRY=Germany
STORE_PHONE=
STORE_VAT_ID=

# --------------------------------------------------------------------
# Pickup profile
# --------------------------------------------------------------------

STORE_PICKUP_LABEL=Local pickup
STORE_PICKUP_NOTE=Pickup is arranged by email after your order is placed.
STORE_PICKUP_CONTACT_NAME=Your Name
STORE_PICKUP_ADDRESS_LINE1=123 Example Street
STORE_PICKUP_POSTAL_CODE=12345
STORE_PICKUP_CITY=Example City
STORE_PICKUP_COUNTRY=Germany
STORE_PICKUP_PHONE=
STORE_PICKUP_PHONE_LABEL=WhatsApp

# --------------------------------------------------------------------
# Catalog import and media helpers
# Optional helpers for CSV enrichment and image handling.
# --------------------------------------------------------------------

DISCOGS_USER_TOKEN=
DISCOGS_USER_AGENT=YourStore/1.0 +https://your-store.example
BLOB_READ_WRITE_TOKEN=

# --------------------------------------------------------------------
# Local testing helpers
# --------------------------------------------------------------------

TEST_BASE_URL=http://localhost:3000

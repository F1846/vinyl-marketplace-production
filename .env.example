# ─── Database ───────────────────────────────────
# PostgreSQL connection string. Use Vercel Postgres, Supabase, or Neon.
DATABASE_URL="postgresql://user:password@localhost:5432/vinyl_marketplace?sslmode=require"

# ─── Stripe ─────────────────────────────────────
# Stripe Mode: "test" or "live"
STRIPE_MODE="test"

# Secret key from Stripe Dashboard (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key for the frontend (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret from Stripe CLI or Dashboard
# Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Shipping ───────────────────────────────────
# Flat shipping rate in cents (e.g., 899 = $8.99)
SHIPPING_RATE_CENTS="899"

# ─── Admin Authentication ───────────────────────
# Password for the admin panel. Must be a strong password.
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Bcrypt hash of ADMIN_PASSWORD (used in production — generate with: npx ts-node scripts/hash-password.ts)
ADMIN_PASSWORD_HASH=""

# ─── Email (Resend) ─────────────────────────────
# API key from https://resend.com
RESEND_API_KEY="re_..."

# Sender email for transactional emails (must be verified in Resend)
EMAIL_FROM="orders@yourdomain.com"

# ─── Image Upload (Vercel Blob) ─────────────────
# Vercel Blob read/write token from Vercel Dashboard
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ─── Application ─────────────────────────────────
# Public base URL of the site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ─── Logging / Monitoring (Optional) ────────────
SENTRY_DSN=""

# ─── Vercel Deploy (Optional) ───────────────────
# Token from Vercel dashboard for CLI deployment
VERCEL_TOKEN=""

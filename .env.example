# ─── Database ───────────────────────────────────
# PostgreSQL connection string. Use Vercel Postgres, Supabase, or Neon.
DATABASE_URL="postgresql://user:password@localhost:5432/vinyl_marketplace?sslmode=require"

# ─── Stripe ─────────────────────────────────────
# Stripe Mode: "test" or "live"
STRIPE_MODE="test"

# Secret key from Stripe Dashboard (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY="sk_test_..."

# Publishable key for the frontend (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Webhook signing secret from Stripe CLI or Dashboard
# Stripe CLI: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─── Shipping ───────────────────────────────────
# Shipping rates live in the database and are managed in /admin/shipping.
# The shipping migration seeds starter rules for DE, FR, US, and ALL-country fallbacks.

# ─── Admin Authentication ───────────────────────
# Password for the admin panel. Must be a strong password.
ADMIN_PASSWORD="change-me-to-a-strong-password"
# Bcrypt hash of ADMIN_PASSWORD (used in production — generate with: npx ts-node scripts/hash-password.ts)
ADMIN_PASSWORD_HASH=""
# Optional dedicated secret used to sign the admin session cookie.
ADMIN_SESSION_SECRET=""
# Optional secret used to sign redirect-based checkout state (PayPal return flow).
CHECKOUT_STATE_SECRET=""

# ─── Email (Mailgun) ────────────────────────────
# API key from https://app.mailgun.com/
MAILGUN_API_KEY="key-..."
# Domain from Mailgun, for example sandbox123.mailgun.org or mg.yourdomain.com
MAILGUN_DOMAIN="sandbox123.mailgun.org"
# Optional override for regional endpoints; defaults to https://api.mailgun.net
MAILGUN_BASE_URL="https://api.mailgun.net"
# Optional display name for Mailgun transactional emails
EMAIL_FROM_NAME="Federico Shop DE"
# Sender email for transactional emails (must be verified in Mailgun)
EMAIL_FROM="Federico Shop DE <orders@yourdomain.com>"
# Optional BCC copy of every transactional email
EMAIL_BCC=""
# Optional test recipient for local email checks
TEST_NOTIFICATION_EMAIL=""

# ─── Image Upload (Vercel Blob) ─────────────────
# Vercel Blob read/write token from Vercel Dashboard
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Discogs Import
# Personal access token from Discogs developer settings, used for inventory imports and cover art sync.
DISCOGS_USER_TOKEN=""
# Optional custom user agent for Discogs API requests.
DISCOGS_USER_AGENT="federico-shop/1.0 +https://www.federicoshop.de"

# PayPal Checkout
PAYPAL_ENVIRONMENT="sandbox"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
NEXT_PUBLIC_PAYPAL_ENABLED="false"

# Tracking Sync
# Free option: 17TRACK API supports 100 free quotas per month, and repeated automatic
# tracking updates for already-registered numbers do not consume extra quota.
# Set TRACKING_PROVIDER="17track" to prefer the free provider, or "aftership" for AfterShip.
TRACKING_PROVIDER="17track"
# Free live-tracking provider key from 17TRACK API settings.
SEVENTEENTRACK_API_KEY=""
# Optional paid alternative from AfterShip.
AFTERSHIP_API_KEY=""
# Secret for the scheduled tracking sync route.
CRON_SECRET=""

# ─── Application ─────────────────────────────────
# Public base URL of the site
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
STORE_OWNER="Federico Shop"
STORE_CONTACT_EMAIL="orders@federicoshop.de"
STORE_EMERGENCY_EMAIL="sandrodoglio40@gmail.com"
STORE_EMERGENCY_EMAIL_NOTE="Emergency temporary contact while the domain mailbox setup is being finalized."
STORE_ADDRESS_LINE1="Okerstr"
STORE_ADDRESS_LINE2=""
STORE_POSTAL_CODE="12049"
STORE_CITY="Neukolln Berlin"
STORE_COUNTRY="Germany"
STORE_PHONE=""
STORE_VAT_ID=""
STORE_PICKUP_LABEL="Berlin Neukolln : 12049"
STORE_PICKUP_NOTE="Pickup is arranged by email after your order is placed."

# ─── Logging / Monitoring (Optional) ────────────
SENTRY_DSN=""

# ─── Vercel Deploy (Optional) ───────────────────
# Token from Vercel dashboard for CLI deployment
VERCEL_TOKEN=""

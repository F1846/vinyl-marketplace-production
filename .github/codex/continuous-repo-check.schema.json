{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result",
    "branch_topic",
    "commit_message",
    "pr_title",
    "pr_body",
    "findings_summary",
    "validation_summary",
    "review_status"
  ],
  "properties": {
    "result": {
      "type": "string",
      "enum": ["fix_applied", "report_only", "no_action"]
    },
    "branch_topic": {
      "type": "string",
      "minLength": 0,
      "maxLength": 40,
      "pattern": "^[a-z0-9]+(?:-[a-z0-9]+){0,5}$|^$"
    },
    "commit_message": {
      "type": "string",
      "minLength": 0,
      "maxLength": 120
    },
    "pr_title": {
      "type": "string",
      "minLength": 0,
      "maxLength": 120
    },
    "pr_body": {
      "type": "string",
      "minLength": 0,
      "maxLength": 20000
    },
    "findings_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000
    },
    "validation_summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 5000
    },
    "review_status": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    }
  }
}
